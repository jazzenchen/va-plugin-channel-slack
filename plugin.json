{
  "id": "slack",
  "name": "Slack Channel",
  "version": "0.6.7",
  "kind": "channel",
  "runtime": "node",
  "entry": "dist/main.js",
  "build": "npm install && npm run build",
  "minHostVersion": "0.1.0",
  "configSchema": {
    "type": "object",
    "properties": {
      "bot_token": { "type": "string", "description": "Slack Bot Token (xoxb-...)" },
      "app_token": { "type": "string", "description": "Slack App-Level Token for Socket Mode (xapp-...)" }
    },
    "required": ["bot_token", "app_token"]
  },
  "capabilities": {
    "streaming": true,
    "interactiveCards": true,
    "reactions": true,
    "editMessage": true,
    "media": true
  }
}
