{
  "display_information": {
    "name": "VibeAround"
  },
  "features": {
    "bot_user": {
      "display_name": "VibeAround",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/va",
        "description": "VibeAround command (e.g. /va help, /va switch claude)",
        "should_escape": false
      },
      {
        "command": "/vibearound",
        "description": "VibeAround command",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "files:read",
        "app_mentions:read",
        "chat:write",
        "commands",
        "im:history",
        "im:read",
        "im:write"
      ]
    },
    "pkce_enabled": false
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false,
    "is_mcp_enabled": false
  }
}
